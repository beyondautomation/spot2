{
    "timeout": 10,
    "source": {
        "directories": ["src"]
    },
    "logs": {
        "text": "infection.log",
        "html": "infection.html",
        "summary": "infection-summary.log"
    },
    "mutators": {
        "@default": true
    },
    "testFramework": "phpunit",
    "testFrameworkOptions": "--configuration phpunit_sqlite.xml",
    "minMsi": 60,
    "minCoveredMsi": 70
}
