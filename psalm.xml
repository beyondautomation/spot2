<?xml version="1.0"?>
<psalm
    errorLevel="3"
    resolveFromConfigFile="true"
    findUnusedVariablesAndParams="false"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
>
    <projectFiles>
        <directory name="src" />
        <ignoreFiles>
            <directory name="vendor" />
            <directory name="tests" />
        </ignoreFiles>
    </projectFiles>

    <issueHandlers>
        <!--
            Library public API — PossiblyUnusedMethod/Class/Property are
            false positives; consumers call these from outside the codebase.
        -->
        <PossiblyUnusedMethod errorLevel="suppress" />
        <PossiblyUnusedReturnValue errorLevel="suppress" />
        <PossiblyUnusedParam errorLevel="suppress" />
        <PossiblyUnusedProperty errorLevel="suppress" />
        <UnusedClass errorLevel="suppress" />

        <!--
            ClassMustBeFinal: Spot is designed for extension — Mapper, Entity,
            Query and all relation classes are explicitly subclassable by users.
        -->
        <ClassMustBeFinal errorLevel="suppress" />

        <!--
            InvalidStringClass: dynamic $entityName::method() calls are the
            core ORM dispatch pattern. Psalm cannot resolve string class names.
        -->
        <InvalidStringClass errorLevel="suppress" />

        <!--
            UnsafeInstantiation: new $className() is used throughout for
            pluggable query/collection/entity classes. Intentional design.
        -->
        <UnsafeInstantiation errorLevel="suppress" />

        <!--
            DeprecatedMethod: DBAL4 deprecated quoteIdentifier, introspectTable
            and setPrimaryKey. Will be addressed when DBAL5 is targeted.
        -->
        <DeprecatedMethod errorLevel="suppress" />

        <!--
            RiskyTruthyFalsyComparison: nullable string / mixed falsy checks
            are intentional legacy patterns throughout Config and Mapper.
        -->
        <RiskyTruthyFalsyComparison errorLevel="suppress" />

        <!--
            Redundant checks that are correct at runtime even if Psalm's
            docblock-driven flow says they are always true/false.
        -->
        <RedundantConditionGivenDocblockType errorLevel="suppress" />
        <RedundantCastGivenDocblockType errorLevel="suppress" />
        <DocblockTypeContradiction errorLevel="suppress" />

        <!--
            PossiblyNullOperand: escapeIdentifier() returns string|array,
            Psalm infers null in the TypeDoesNotContainType suppressed path.
        -->
        <PossiblyNullOperand errorLevel="suppress" />

        <!--
            MissingOverrideAttribute: Psalm 6 wants #[\Override] on interface
            implementations. Cosmetic — suppress globally.
        -->
        <MissingOverrideAttribute errorLevel="suppress" />
        <MissingParamType errorLevel="suppress" />

        <!--
            UnsupportedPropertyReferenceUsage / ReferenceReusedFromConfusingScope:
            Entity::__get() uses PHP references intentionally for performance.
        -->
        <UnsupportedPropertyReferenceUsage errorLevel="suppress" />
        <ReferenceReusedFromConfusingScope errorLevel="suppress" />

        <!--
            InvalidArrayOffset: Collection::offsetUnset offset type from SPL.
        -->
        <InvalidArrayOffset errorLevel="suppress" />

        <!--
            ArgumentTypeCoercion: Config::parseDsn passes array<string,mixed>
            to DBAL's strict typed connection params.
        -->
        <ArgumentTypeCoercion errorLevel="suppress" />

        <!--
            NullArgument: QueryBuilder::set(null) intentionally nulls FK columns.
        -->
        <NullArgument errorLevel="suppress" />

        <!--
            InvalidArgument: Spot's relation save() passes arrays to DBAL
            QueryBuilder methods that expect string|CompositeExpression.
        -->
        <InvalidArgument errorLevel="suppress" />

        <!--
            UndefinedMagicMethod: HasManyThrough implements IteratorAggregate
            but Psalm can't resolve magic foreach on the relation class.
        -->
        <UndefinedMagicMethod errorLevel="suppress" />

        <!--
            TooManyArguments: Valitron stub is outdated; rule() accepts variadics.
        -->
        <TooManyArguments errorLevel="suppress" />

        <!--
            MissingParamType: test files with PHPUnit @depends methods pass
            $postId as untyped mixed — cannot add types without breaking @depends.
        -->
        <MissingParamType errorLevel="suppress" />

        <!--
            UnnecessaryVarAnnotation: leftover @var on well-typed collections.
        -->
        <UnnecessaryVarAnnotation errorLevel="suppress" />

        <!--
            PossiblyUndefinedArrayOffset: Config::parseDsn legacy DSN parsing.
        -->
        <PossiblyUndefinedArrayOffset errorLevel="suppress" />

        <!--
            NoValue / TypeDoesNotContainType: Psalm flow on escapeIdentifier()
            overload — not a real bug.
        -->
        <NoValue errorLevel="suppress" />
        <TypeDoesNotContainType errorLevel="suppress" />

        <!--
            UnusedForeachValue: $currentField used only for loop key iteration.
        -->
        <UnusedForeachValue errorLevel="suppress" />

        <!--
            RedundantCast: pre-existing defensive casts.
        -->
        <RedundantCast errorLevel="suppress" />

        <!--
            RedundantCondition: operator null/empty checks.
        -->
        <RedundantCondition errorLevel="suppress" />

        <!--
            UndefinedClass: Laravel provider — optional dependency.
        -->
        <UndefinedClass>
            <errorLevel type="suppress">
                <file name="src/Provider/Laravel.php" />
            </errorLevel>
        </UndefinedClass>
    </issueHandlers>
</psalm>
